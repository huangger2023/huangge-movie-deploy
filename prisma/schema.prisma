// Douyin Movie Narration Knowledge-Paid Platform
// 抖音电影解说知识付费平台

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String   @default("123456")
  role         String   @default("STUDENT") // STUDENT | ADMIN
  avatar       String?
  bio          String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollments  Enrollment[]
  scripts      GeneratedScript[]
  toolUsages   ToolUsage[]
  plotDocs     PlotDocument[]
  chatMessages ChatMessage[]
  workspaces   Workspace[]
  tvSeries     TvSeries[]
  lessonCompletions LessonCompletion[]
  activation   UserActivation?
  aiModels     UserAiModel[]
  fenggeChats  FenggeChat[]
}

model Course {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  description   String
  coverImage    String
  category      String   // 入门 | 进阶 | 实战 | 高阶 | 运营
  level         String   // 初级 | 中级 | 高级
  price         Float    @default(0)
  originalPrice Float?
  isFree        Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  isPublished   Boolean  @default(true)
  instructor    String
  instructorBio String?
  instructorAvatar String?
  rating        Float    @default(5.0)
  ratingCount   Int      @default(0)
  studentsCount Int      @default(0)
  totalDuration Int      @default(0) // minutes
  lessonsCount  Int      @default(0)
  tags          String   @default("[]") // JSON array as string
  highlights    String   @default("[]") // JSON array as string
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lessons       Lesson[]
  enrollments   Enrollment[]
  lessonCompletions LessonCompletion[]
}

model Lesson {
  id         String   @id @default(cuid())
  courseId   String
  title      String
  content    String
  videoUrl   String?
  duration   Int      @default(0) // minutes
  order      Int      @default(0)
  isPreview  Boolean  @default(false)
  createdAt  DateTime @default(now())

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completions LessonCompletion[]
}

model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  courseId    String
  completedAt DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
}

model Enrollment {
  id            String    @id @default(cuid())
  userId        String
  courseId      String
  status        String    @default("pending") // pending | approved | rejected
  progress      Float     @default(0) // 0-100
  lastLessonId  String?
  enrolledAt    DateTime  @default(now())
  completedAt   DateTime?
  lastActiveAt  DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model GeneratedScript {
  id          String   @id @default(cuid())
  userId      String
  type        String   // SCRIPT | TITLE | HOOK | POLISH | OUTLINE
  movieTitle  String
  genre       String?
  input       String
  output      String
  meta        String   @default("{}") // JSON metadata
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, createdAt])
}

model ToolUsage {
  id        String   @id @default(cuid())
  userId    String
  toolType  String   // SCRIPT | TITLE | HOOK | POLISH | TTS
  count     Int      @default(1)
  date      DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolType])
}

// 剧情文档库：用户上传/联网抓取的真实剧情描述，供 Agent 创作时读取，避免瞎编
model PlotDocument {
  id          String   @id @default(cuid())
  userId      String
  movieTitle  String
  content     String
  source      String   @default("manual") // manual | web
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, movieTitle])
  @@index([userId, createdAt])
}

// AI 助教对话历史：按课时维度持久化学员与 AI 助教的对话
model ChatMessage {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  role       String   // user | assistant
  content    String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId, createdAt])
}

// 创作工作台：把一部电影的文案/标题/开头/分镜统一到一个项目里管理
model Workspace {
  id          String   @id @default(cuid())
  userId      String
  movieTitle  String
  genre       String   @default("剧情")
  coverColor  String   @default("rose") // 主题色标识
  status      String   @default("draft") // draft | in-progress | done
  script      String?  // 完整解说文案
  titles      String?  // 爆款标题（JSON 数组）
  hooks       String?  // 黄金开头（JSON 数组）
  storyboard  String?  // 分镜表（JSON 数组）
  notes       String?  // 创作笔记
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([userId, status])
}

// AI 模型配置：管理员可自由添加 OpenAI 兼容端点的模型，设其一为默认全局使用
// TTS 与联网搜索仍走智谱 SDK，不受此表影响
model AiModel {
  id        String   @id @default(cuid())
  name      String   // 显示名，后台列表区分用
  baseUrl   String   // OpenAI 兼容端点，如 https://open.bigmodel.cn/api/paas/v4
  apiKey    String   // API Key，明文存（与项目现有密码风格一致），UI 隐藏输入、列表脱敏
  model     String   // 模型名，如 glm-4-flash
  isDefault Boolean  @default(false) // 默认模型（全局唯一）
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 电视剧系列：管理多集字幕数据，供 AI 基于真实对白创作解说
model TvSeries {
  id            String   @id @default(cuid())
  userId        String
  title         String   // 剧名
  totalEpisodes Int      @default(0) // 总集数
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  episodes      Episode[]

  @@index([userId, title])
}

// 电视剧单集：字幕文件解析结果
model Episode {
  id              String   @id @default(cuid())
  tvSeriesId      String
  episodeNumber   Int
  // 原始字幕文本（srt / vtt 原文）
  subtitleRaw     String
  // 结构化字幕 JSON：[{ start, end, text }]
  subtitleParsed  String
  createdAt       DateTime @default(now())

  tvSeries        TvSeries @relation(fields: [tvSeriesId], references: [id], onDelete: Cascade)

  @@unique([tvSeriesId, episodeNumber])
}

// 用户自有 AI 模型配置：普通用户可添加自己的 OpenAI 兼容端点，
// 优先使用自己的模型；未配置时回退到管理员全局默认模型（受公开开关控制）
model UserAiModel {
  id        String   @id @default(cuid())
  userId    String
  name      String   // 显示名
  baseUrl   String   // OpenAI 兼容端点
  apiKey    String   // API Key，明文存，UI 脱敏
  model     String   // 模型名，如 glm-4-flash
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 「和荒哥聊聊」对话历史：按会话维度持久化用户与荒哥的对话（不绑课时）
model FenggeChat {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId, createdAt])
}

// 「和荒哥聊聊」游客限额计数：用 cookie id 关联，软门槛引流
model FenggeGuest {
  id        String   @id @default(cuid())
  turnCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 系统设置：键值对存储，如授权开关
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// 用户授权激活记录：绑定机器码与激活码
model UserActivation {
  id          String   @id @default(cuid())
  userId      String   @unique
  machineId   String
  licenseKey  String
  expireDate  DateTime
  activatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([machineId])
}
