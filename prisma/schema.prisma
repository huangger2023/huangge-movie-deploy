// Douyin Movie Narration Knowledge-Paid Platform
// 抖音电影解说知识付费平台

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String   @default("123456")
  role         String   @default("STUDENT") // STUDENT | ADMIN
  avatar       String?
  bio          String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollments  Enrollment[]
  scripts      GeneratedScript[]
  toolUsages   ToolUsage[]
  plotDocs     PlotDocument[]
}

model Course {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  description   String
  coverImage    String
  category      String   // 入门 | 进阶 | 实战 | 高阶 | 运营
  level         String   // 初级 | 中级 | 高级
  price         Float    @default(0)
  originalPrice Float?
  isFree        Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  isPublished   Boolean  @default(true)
  instructor    String
  instructorBio String?
  instructorAvatar String?
  rating        Float    @default(5.0)
  ratingCount   Int      @default(0)
  studentsCount Int      @default(0)
  totalDuration Int      @default(0) // minutes
  lessonsCount  Int      @default(0)
  tags          String   @default("[]") // JSON array as string
  highlights    String   @default("[]") // JSON array as string
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lessons       Lesson[]
  enrollments   Enrollment[]
}

model Lesson {
  id         String   @id @default(cuid())
  courseId   String
  title      String
  content    String
  videoUrl   String?
  duration   Int      @default(0) // minutes
  order      Int      @default(0)
  isPreview  Boolean  @default(false)
  createdAt  DateTime @default(now())

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id            String    @id @default(cuid())
  userId        String
  courseId      String
  progress      Float     @default(0) // 0-100
  lastLessonId  String?
  enrolledAt    DateTime  @default(now())
  completedAt   DateTime?
  lastActiveAt  DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model GeneratedScript {
  id          String   @id @default(cuid())
  userId      String
  type        String   // SCRIPT | TITLE | HOOK | POLISH | OUTLINE
  movieTitle  String
  genre       String?
  input       String
  output      String
  meta        String   @default("{}") // JSON metadata
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, createdAt])
}

model ToolUsage {
  id        String   @id @default(cuid())
  userId    String
  toolType  String   // SCRIPT | TITLE | HOOK | POLISH | TTS
  count     Int      @default(1)
  date      DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolType])
}

// 剧情文档库：用户上传/联网抓取的真实剧情描述，供 Agent 创作时读取，避免瞎编
model PlotDocument {
  id          String   @id @default(cuid())
  userId      String
  movieTitle  String
  content     String
  source      String   @default("manual") // manual | web
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, movieTitle])
  @@index([userId, createdAt])
}
